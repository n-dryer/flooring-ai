---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "AI Automation for Flooring Contractors | Book More Jobs, Save Time",
	description = "Practical AI automation tools for LA flooring installation contractors. Save time, never miss leads, and grow your business with smart systems.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="font-body bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100"
	>
		<header
			class="sticky top-0 z-50 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm shadow-sm"
		>
			<div
				class="container mx-auto px-4 py-4 flex justify-between items-center"
			>
				<a
					href="/"
					class="text-xl font-bold text-blue-600 dark:text-blue-400 flex items-center gap-2"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="icon icon-tabler icon-tabler-robot"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						fill="none"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path stroke="none" d="M0 0h24v24H0z" fill="none"
						></path>
						<path
							d="M7 7h10a2 2 0 0 1 2 2v1l1 1v3l-1 1v3a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-3l-1 -1v-3l1 -1v-1a2 2 0 0 1 2 -2z"
						></path>
						<path d="M10 16h4"></path>
						<circle cx="8.5" cy="11.5" r=".5" fill="currentColor"
						></circle>
						<circle cx="15.5" cy="11.5" r=".5" fill="currentColor"
						></circle>
					</svg>
					FlooringAI
				</a>
				<nav class="hidden md:flex gap-6">
					<a
						href="/"
						class="font-medium hover:text-blue-600 dark:hover:text-blue-400 transition"
						>Home</a
					>
					<a
						href="/services"
						class="font-medium hover:text-blue-600 dark:hover:text-blue-400 transition"
						>Services</a
					>
				</nav>
				<a
					href="/contact"
					class="hidden md:inline-flex px-4 py-2 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-medium rounded-md hover:from-orange-600 hover:to-orange-700 transition shadow-sm"
				>
					Schedule Now
				</a>
				<button
					id="mobile-menu-button"
					class="md:hidden text-gray-800 dark:text-gray-200"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-6 w-6"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
			</div>
			<div
				id="mobile-menu"
				class="md:hidden hidden bg-white dark:bg-gray-900 shadow-md pb-4"
			>
				<nav class="container mx-auto px-4 flex flex-col gap-3">
					<a
						href="/"
						class="py-2 font-medium hover:text-blue-600 dark:hover:text-blue-400 transition"
						>Home</a
					>
					<a
						href="/services"
						class="py-2 font-medium hover:text-blue-600 dark:hover:text-blue-400 transition"
						>Services</a
					>
					<a
						href="/contact"
						class="mt-2 px-4 py-2 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-medium rounded-md hover:from-orange-600 hover:to-orange-700 transition shadow-sm text-center"
					>
						Schedule Now
					</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-900 text-gray-300 mt-24 py-12">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div>
						<a
							href="/"
							class="text-xl font-bold text-blue-400 flex items-center gap-2 mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="icon icon-tabler icon-tabler-robot"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								stroke-width="2"
								stroke="currentColor"
								fill="none"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									stroke="none"
									d="M0 0h24v24H0z"
									fill="none"></path>
								<path
									d="M7 7h10a2 2 0 0 1 2 2v1l1 1v3l-1 1v3a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-3l-1 -1v-3l1 -1v-1a2 2 0 0 1 2 -2z"
								></path>
								<path d="M10 16h4"></path>
								<circle
									cx="8.5"
									cy="11.5"
									r=".5"
									fill="currentColor"></circle>
								<circle
									cx="15.5"
									cy="11.5"
									r=".5"
									fill="currentColor"></circle>
							</svg>
							FlooringAI
						</a>
						<p class="text-sm">
							Practical AI automation for flooring installation
							businesses in Los Angeles. Save time, never miss
							leads, and grow your business.
						</p>
					</div>
					<div>
						<h3 class="text-lg font-medium mb-4 text-white">
							Quick Links
						</h3>
						<nav class="flex flex-col gap-2">
							<a
								href="/"
								class="text-sm hover:text-blue-400 transition"
								>Home</a
							>
							<a
								href="/services"
								class="text-sm hover:text-blue-400 transition"
								>Services</a
							>
							<a
								href="/contact"
								class="text-sm hover:text-blue-400 transition"
								>Schedule Consultation</a
							>
						</nav>
					</div>
					<div>
						<h3 class="text-lg font-medium mb-4 text-white">
							Contact
						</h3>
						<p class="text-sm mb-4">
							Serving flooring contractors nationwide
						</p>
						<a
							href="/contact"
							class="inline-flex px-4 py-2 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-medium rounded-md hover:from-orange-600 hover:to-orange-700 transition shadow-sm text-sm"
						>
							Schedule Your Free Consultation
						</a>
					</div>
				</div>
				<div
					class="border-t border-gray-800 mt-8 pt-8 text-sm text-center"
				>
					<p>
						&copy; {new Date().getFullYear()} FlooringAI. All rights
						reserved.
					</p>
				</div>
			</div>
		</footer>

		<script>
			// Mobile menu toggle
			const mobileMenuButton =
				document.getElementById("mobile-menu-button");
			const mobileMenu = document.getElementById("mobile-menu");

			mobileMenuButton?.addEventListener("click", () => {
				mobileMenu?.classList.toggle("hidden");
			});
		</script>
	</body>
</html>
