---
import "../utils/theme";
---

<button
  id="theme-toggle"
  class="p-2.5 rounded-full bg-gray-100 dark:bg-gray-800 transition-all duration-300 hover:bg-gray-200 dark:hover:bg-gray-700 shadow-sm hover:shadow-md transform hover:scale-105 border border-gray-200/50 dark:border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 group"
  aria-label="Toggle dark mode"
>
  <div class="relative w-5 h-5 overflow-hidden">
    <!-- Sun icon (visible in dark mode) -->
    <svg
      class="w-5 h-5 absolute top-0 left-0 transition-all duration-500 ease-out dark:rotate-0 dark:opacity-100 dark:scale-100 rotate-90 opacity-0 scale-75 text-amber-400 group-hover:text-amber-500 dark:group-hover:text-amber-300"
      fill="currentColor"
      viewBox="0 0 20 20"
      aria-hidden="true"
    >
      <path
        d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
      ></path>
    </svg>

    <!-- Moon icon (visible in light mode) -->
    <svg
      class="w-5 h-5 absolute top-0 left-0 transition-all duration-500 ease-out dark:rotate-90 dark:opacity-0 dark:scale-75 rotate-0 opacity-100 scale-100 text-primary-600 group-hover:text-primary-700 dark:group-hover:text-primary-400"
      fill="currentColor"
      viewBox="0 0 20 20"
      aria-hidden="true"
    >
      <path
        d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
      ></path>
    </svg>
  </div>
</button>

<script>
  import { initTheme, toggleTheme } from "../utils/theme";

  // Initialize theme on page load
  if (typeof document !== "undefined") {
    // Run immediately to prevent flash of incorrect theme
    initTheme();

    // Also run on DOMContentLoaded to ensure everything is ready
    document.addEventListener("DOMContentLoaded", () => {
      initTheme();
    });

    // Add event listener for theme toggle button
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      toggleTheme();

      // Add animation class for smooth transition
      const button = document.getElementById("theme-toggle");
      button?.classList.add("animate-pulse-slow");

      // Remove animation class after transition completes
      setTimeout(() => {
        button?.classList.remove("animate-pulse-slow");
      }, 500);
    });

    // Listen for system preference changes
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", (e) => {
        if (localStorage.getItem("theme") === "system") {
          document.documentElement.classList.toggle("dark", e.matches);
        }
      });
  }
</script>
