---
const isProd = import.meta.env.PROD;
const GA_ID = import.meta.env.PUBLIC_GA_ID;
---

{isProd && (
  <>
    <!-- Google Analytics -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>

    <!-- Initialize Analytics Event Listeners -->
    <script>
      // Import the Analytics class
      import { Analytics } from '../utils/analytics';

      // Initialize event listeners when the DOM is ready
      document.addEventListener('DOMContentLoaded', () => {
        Analytics.initEventListeners();
      });

      // Track initial page view
      Analytics.trackPageView({
        path: window.location.pathname,
        title: document.title
      });
    </script>
  </>
)}
