---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="AI Automation for Floor Service Businesses | FlooringAI"
	description="Stop missing leads & start booking more floor service jobs with AI automation. Practical solutions for flooring installation and cleaning businesses."
>
	<!-- Hero Section -->
	<section class="relative text-white py-20 md:py-32 overflow-hidden">
		<!-- Abstract background shapes -->
		<div class="absolute inset-0 opacity-10">
			<div class="absolute top-0 left-0 w-full h-full">
				<div
					class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-400 rounded-full filter blur-3xl opacity-20 animate-pulse"
				>
				</div>
				<div
					class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-secondary-500 rounded-full filter blur-3xl opacity-20 animate-pulse"
					style="animation-delay: 2s"
				>
				</div>
				<div
					class="absolute top-1/2 right-1/3 w-64 h-64 bg-accent-500 rounded-full filter blur-3xl opacity-20 animate-pulse"
					style="animation-delay: 4s"
				>
				</div>
			</div>
		</div>

		<div class="container relative z-10">
			<div class="max-w-3xl mx-auto text-center">
				<div
					class="inline-block mb-3 px-3 py-1 bg-primary-800/50 rounded-full text-primary-200 text-sm font-medium animate-fade-in-up"
				>
					Trusted by Top Flooring Contractors
				</div>
				<h1
					class="mb-6 animate-fade-in-up text-4xl md:text-5xl lg:text-6xl font-heading font-bold tracking-tight text-shadow-lg"
				>
					AI Automation for Floor Service Businesses
				</h1>
				<p
					class="text-xl md:text-2xl mb-8 text-primary-100 animate-fade-in-up [animation-delay:200ms] leading-relaxed text-shadow-md"
				>
					Practical AI solutions that help flooring contractors save
					time, never miss leads, and book more jobs.
				</p>
				<div
					class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up [animation-delay:400ms]"
				>
					<a href="/contact" class="btn btn-primary text-lg">
						Schedule Consultation
					</a>
					<a href="/services" class="btn btn-secondary text-lg">
						View Solutions
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Solutions Grid -->
	<section class="py-24">
		<div class="container">
			<div class="text-center mb-16">
				<div
					class="inline-block mb-3 px-3 py-1 bg-primary-800/50 rounded-full text-primary-200 text-sm font-medium"
				>
					Tailored for Flooring Professionals
				</div>
				<h2
					class="text-3xl md:text-4xl font-heading font-bold mb-4 text-white text-shadow-md"
				>
					AI Solutions for Flooring Businesses
				</h2>
				<p class="text-white/80 max-w-2xl mx-auto text-lg">
					Practical automation tools designed specifically for
					flooring installation and cleaning businesses.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-8 lg:gap-12">
				<!-- AI Solutions Column -->
				<div class="space-y-6 glass-effect card">
					<div
						class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
							></path>
						</svg>
					</div>
					<h3
						class="text-xl font-semibold text-neutral-900 dark:text-white"
					>
						Lead Generation & Response
					</h3>

					<div
						class="border-t border-neutral-200 dark:border-neutral-800 pt-4"
					>
						<div class="flex items-start gap-3">
							<div
								class="flex-shrink-0 mt-1 text-accent-500 dark:text-accent-400"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-5 w-5"
									viewBox="0 0 20 20"
									fill="currentColor"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-medium mb-1 text-neutral-900 dark:text-white"
								>
									24/7 Lead Capture
								</h4>
								<p
									class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
								>
									Never miss another lead with AI-powered
									response system, even after hours.
								</p>
							</div>
						</div>
					</div>

					<div
						class="border-t border-neutral-200 dark:border-neutral-800 pt-4"
					>
						<div class="flex items-start gap-3">
							<div
								class="flex-shrink-0 mt-1 text-accent-500 dark:text-accent-400"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-5 w-5"
									viewBox="0 0 20 20"
									fill="currentColor"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-medium mb-1 text-neutral-900 dark:text-white"
								>
									Instant Quote Calculator
								</h4>
								<p
									class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
								>
									AI-powered estimator for flooring projects
									in the LA area.
								</p>
							</div>
						</div>
					</div>

					<div
						class="flex items-start gap-4 group hover:bg-white/5 p-4 rounded-lg transition-colors"
					>
						<div class="text-primary-500 dark:text-primary-400">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-6 w-6"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
								></path>
							</svg>
						</div>
						<div>
							<h4
								class="font-medium mb-2 text-gray-900 dark:text-white"
							>
								Automated Follow-ups
							</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300">
								Smart follow-up system that keeps leads warm and
								converts more jobs.
							</p>
						</div>
					</div>
				</div>

				<!-- Business Operations Column -->
				<div class="space-y-6 glass-effect card">
					<h3
						class="text-xl font-semibold text-gray-900 dark:text-white mb-6"
					>
						BUSINESS OPERATIONS
					</h3>

					<div
						class="flex items-start gap-4 group hover:bg-white/5 p-4 rounded-lg transition-colors"
					>
						<div class="text-primary-500 dark:text-primary-400">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-6 w-6"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
								></path>
							</svg>
						</div>
						<div>
							<h4
								class="font-medium mb-2 text-gray-900 dark:text-white"
							>
								Smart Scheduling
							</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300">
								Optimize your team's schedule across Los Angeles
								job sites.
							</p>
						</div>
					</div>

					<div
						class="border-t border-neutral-200 dark:border-neutral-800 pt-4"
					>
						<div class="flex items-start gap-3">
							<div
								class="flex-shrink-0 mt-1 text-accent-500 dark:text-accent-400"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-5 w-5"
									viewBox="0 0 20 20"
									fill="currentColor"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-medium mb-1 text-neutral-900 dark:text-white"
								>
									AI Phone System
								</h4>
								<p
									class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
								>
									Automated call handling for your LA floor
									service business.
								</p>
							</div>
						</div>
					</div>

					<div
						class="border-t border-neutral-200 dark:border-neutral-800 pt-4"
					>
						<div class="flex items-start gap-3">
							<div
								class="flex-shrink-0 mt-1 text-accent-500 dark:text-accent-400"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-5 w-5"
									viewBox="0 0 20 20"
									fill="currentColor"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-medium mb-1 text-neutral-900 dark:text-white"
								>
									Appointment Scheduling
								</h4>
								<p
									class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed"
								>
									Manage bookings with AI for your LA floor
									service business.
								</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Workflow Automation Column -->
				<div class="space-y-6 glass-effect card">
					<div
						class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-secondary-100 dark:bg-secondary-900/30 text-secondary-600 dark:text-secondary-400"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
							></path>
						</svg>
					</div>
					<h3
						class="text-xl font-semibold text-neutral-900 dark:text-white"
					>
						Workflow Automation
					</h3>

					<div
						class="flex items-start gap-4 group hover:bg-white/5 p-4 rounded-lg transition-colors"
					>
						<div class="text-primary-500 dark:text-primary-400">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-6 w-6"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
								></path>
							</svg>
						</div>
						<div>
							<h4
								class="font-medium mb-2 text-gray-900 dark:text-white"
							>
								Task Management
							</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300">
								Coordinate your team easily for LA floor service
								jobs.
							</p>
						</div>
					</div>

					<div
						class="flex items-start gap-4 group hover:bg-white/5 p-4 rounded-lg transition-colors"
					>
						<div class="text-primary-500 dark:text-primary-400">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-6 w-6"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
								></path>
							</svg>
						</div>
						<div>
							<h4
								class="font-medium mb-2 text-gray-900 dark:text-white"
							>
								Lead Tracking
							</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300">
								Monitor and manage leads for your LA floor
								service business.
							</p>
						</div>
					</div>

					<div
						class="flex items-start gap-4 group hover:bg-white/5 p-4 rounded-lg transition-colors"
					>
						<div class="text-primary-500 dark:text-primary-400">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-6 w-6"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"
								></path>
							</svg>
						</div>
						<div>
							<h4
								class="font-medium mb-2 text-gray-900 dark:text-white"
							>
								Message Taking
							</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300">
								Never miss messages from your LA floor service
								clients.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Benefits Section -->
	<section class="py-16">
		<div class="container">
			<div class="grid md:grid-cols-3 gap-8 text-center text-white">
				<div class="glass-effect card">
					<div class="text-primary-500 mb-4">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-12 w-12 mx-auto"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-medium mb-2 text-shadow-sm">
						AI-powered lead management
					</h3>
					<p class="text-white/80">
						Capture and convert more leads automatically.
					</p>
				</div>

				<div class="glass-effect card">
					<div class="text-primary-500 mb-4">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-12 w-12 mx-auto"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
							></path>
						</svg>
					</div>
					<h3 class="text-lg font-medium mb-2 text-shadow-sm">
						Round-the-clock chat support
					</h3>
					<p class="text-white/80">
						Always available to help your customers.
					</p>
				</div>

				<div class="glass-effect card">
					<div class="text-primary-500 mb-4">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-12 w-12 mx-auto"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
							></path>
						</svg>
					</div>
					<h3 class="text-lg font-medium mb-2 text-shadow-sm">
						Seamless CRM connectivity
					</h3>
					<p class="text-white/80">
						Everything integrated in one place.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Final CTA Section -->
	<section class="py-16 text-white">
		<div class="container text-center glass-effect p-8 rounded-xl">
			<h2
				class="mb-6 fade-in-up text-3xl md:text-4xl font-heading font-bold text-shadow-md"
			>
				Ready to Save Time and Book More Flooring Jobs?
			</h2>
			<p class="text-xl mb-8 max-w-2xl mx-auto fade-in-up text-shadow-sm">
				Let's chat for 15 minutes about your specific business goals and
				see how simple AI automation can make a difference. No pressure,
				just practical insights.
			</p>
			<a href="/contact" class="btn btn-primary text-lg fade-in-up">
				Schedule Your Free Consultation Now
			</a>
		</div>
	</section>
</Layout>
