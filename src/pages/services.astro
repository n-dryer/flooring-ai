---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="AI Automation Services for Flooring Contractors | FlooringAI"
    description="Practical AI automation services for flooring installation contractors. Lead capture, follow-ups, phone answering, and CRM solutions."
>
    <!-- Services Hero -->
    <section
        class="relative text-white py-20 md:py-32 overflow-hidden section-overlay hero-overlay"
    >
        <!-- Abstract background shapes -->
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 left-0 w-full h-full">
                <div
                    class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-400 rounded-full filter blur-3xl opacity-20 animate-pulse"
                >
                </div>
                <div
                    class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-secondary-500 rounded-full filter blur-3xl opacity-20 animate-pulse"
                    style="animation-delay: 2s"
                >
                </div>
                <div
                    class="absolute top-1/2 right-1/3 w-64 h-64 bg-accent-500 rounded-full filter blur-3xl opacity-20 animate-pulse"
                    style="animation-delay: 4s"
                >
                </div>
            </div>
        </div>

        <div class="container relative z-10">
            <div class="max-w-3xl mx-auto text-center">
                <div
                    class="inline-block mb-3 px-3 py-1 bg-primary-800/50 rounded-full text-primary-200 text-sm font-medium animate-fade-in-up"
                >
                    Tailored for Flooring Professionals
                </div>
                <h1
                    class="mb-6 animate-fade-in-up text-4xl md:text-5xl lg:text-6xl font-heading font-bold tracking-tight"
                >
                    Practical AI Automation Services
                </h1>
                <p
                    class="text-xl md:text-2xl mb-8 text-primary-100 animate-fade-in-up [animation-delay:200ms] leading-relaxed"
                >
                    We offer focused implementation services designed to solve
                    the biggest front-office headaches for busy flooring
                    business owners. Our goal is simple: save you time, help you
                    book more jobs, and make managing your business easier.
                </p>
            </div>
        </div>
    </section>

    <!-- Services List -->
    <section class="py-24 section-overlay">
        <div class="container">
            <!-- Service 1 -->
            <div class="service-card card mb-16 fade-in-up">
                <div class="flex flex-col md:flex-row gap-8">
                    <div class="md:w-1/3">
                        <div
                            class="bg-blue-100 dark:bg-blue-900 p-4 rounded-full w-24 h-24 flex items-center justify-center mb-6 mx-auto md:mx-0"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="service-icon text-blue-600 dark:text-blue-300"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                                ></path>
                            </svg>
                        </div>
                        <h2
                            class="text-2xl md:text-3xl mb-4 text-center md:text-left text-white"
                        >
                            AI Lead Capture & Instant Response
                        </h2>
                    </div>
                    <div class="md:w-2/3">
                        <div class="mb-6">
                            <h3 class="text-xl text-red-400 mb-2 font-semibold">
                                The Problem:
                            </h3>
                            <p class="text-white/80 mb-2">
                                Missing website leads because you're on-site or
                                it's after hours? Slow responses costing you
                                jobs?
                            </p>
                        </div>
                        <div class="mb-6">
                            <h3
                                class="text-xl text-green-400 mb-2 font-semibold"
                            >
                                Our Solution:
                            </h3>
                            <p class="text-white/80 mb-2">
                                We set up AI-powered web chat and automated
                                SMS/email responders. Leads get qualified
                                answers instantly, 24/7, and their info lands
                                right in your system.
                            </p>
                        </div>
                        <div>
                            <h3
                                class="text-xl text-blue-400 mb-2 font-semibold"
                            >
                                Benefits:
                            </h3>
                            <ul class="list-disc pl-5 text-white/80 space-y-1">
                                <li>
                                    Capture every lead, even outside business
                                    hours
                                </li>
                                <li>
                                    Improve conversion rates with instant
                                    responses
                                </li>
                                <li>
                                    Provide professional first impression to
                                    potential clients
                                </li>
                                <li>
                                    Automate lead qualification and data
                                    collection
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Service 2 -->
            <div class="service-card card mb-16 fade-in-up">
                <div class="flex flex-col md:flex-row gap-8">
                    <div class="md:w-1/3">
                        <div
                            class="bg-green-100 dark:bg-green-900 p-4 rounded-full w-24 h-24 flex items-center justify-center mb-6 mx-auto md:mx-0"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="service-icon text-green-600 dark:text-green-300"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                                ></path>
                            </svg>
                        </div>
                        <h2
                            class="text-2xl md:text-3xl mb-4 text-center md:text-left text-white"
                        >
                            Automated Follow-ups & Appointment Reminders
                        </h2>
                    </div>
                    <div class="md:w-2/3">
                        <div class="mb-6">
                            <h3 class="text-xl text-red-400 mb-2 font-semibold">
                                The Problem:
                            </h3>
                            <p class="text-white/80 mb-2">
                                Forgetting to follow up on quotes? Dealing with
                                costly no-shows or last-minute reschedules?
                            </p>
                        </div>
                        <div class="mb-6">
                            <h3
                                class="text-xl text-green-400 mb-2 font-semibold"
                            >
                                Our Solution:
                            </h3>
                            <p class="text-white/80 mb-2">
                                We configure automated, personalized SMS and
                                email sequences to remind clients of
                                appointments and gently follow up on outstanding
                                quotes after a set time.
                            </p>
                        </div>
                        <div>
                            <h3
                                class="text-xl text-blue-400 mb-2 font-semibold"
                            >
                                Benefits:
                            </h3>
                            <ul class="list-disc pl-5 text-white/80 space-y-1">
                                <li>Increase quote conversion by up to 40%</li>
                                <li>
                                    Drastically reduce no-shows and last-minute
                                    cancellations
                                </li>
                                <li>Save hours on manual reminder calls</li>
                                <li>
                                    Provide professional, consistent
                                    communication
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <section class="section section-overlay">
            <div class="container">
                <div class="max-w-3xl mx-auto text-center">
                    <h2 class="mb-6 fade-in-up">
                        Ready to Automate Your Flooring Business?
                    </h2>
                    <p
                        class="text-xl mb-8 text-gray-700 dark:text-gray-300 fade-in-up"
                    >
                        Let's talk about which services would benefit your
                        specific flooring installation business the most.
                    </p>
                    <a
                        href="/contact"
                        class="btn btn-primary text-lg fade-in-up"
                    >
                        Schedule Your Free Consultation
                    </a>
                </div>
            </div>
        </section>
    </section>
</Layout>
